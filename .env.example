# =============================================================================
# FastMVC — consolidated environment template
# =============================================================================
# Copy to `.env` and customize. Configuration is validated on startup
# (`utilities/validator.py`). For Docker Compose, this same file is typically
# copied to `.env` at the repo root so Compose can substitute variables.
#
# Quotes are optional for simple values; use quotes if a value has spaces.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="FastMVC"
APP_VERSION="1.0.1"
APP_ENV="development"
DEBUG="false"
LOG_LEVEL="INFO"
LOG_FORMAT="json"
# HOST/PORT are what `app.py` / uvicorn use (not APP_HOST / APP_PORT)
HOST="0.0.0.0"
PORT="8000"
# Set to false only for one-off scripts if validation blocks import (e.g. Postman export)
# VALIDATE_CONFIG="true"

# -----------------------------------------------------------------------------
# Security — JWT (validator requires JWT_SECRET_KEY)
# -----------------------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY="change-me-minimum-32-characters-mixed-case-digits-symbols"
# Used by `start_utils` / JWT middleware when enabled — use same value as JWT_SECRET_KEY unless you split concerns
SECRET_KEY="change-me-minimum-32-characters-mixed-case-digits-symbols"
ALGORITHM="HS256"
JWT_AUTH_ENABLED="false"
ACCESS_TOKEN_EXPIRE_MINUTES="1440"
REFRESH_TOKEN_EXPIRE_DAYS="7"
JWT_EXPIRATION_HOURS="24"
BCRYPT_SALT=""

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Prefer DATABASE_URL when set. Examples:
#   postgresql://user:pass@localhost:5432/fastmvc
#   sqlite:///./app.db
DATABASE_URL="sqlite:///./app.db"
# Optional components if you build URL elsewhere:
# DATABASE_HOST="localhost"
# DATABASE_PORT="5432"
# DATABASE_NAME="fastmvc"
# DATABASE_USER="postgres"
# DATABASE_PASSWORD="postgres123"
DATABASE_POOL_SIZE="5"
DATABASE_MAX_OVERFLOW="10"

# -----------------------------------------------------------------------------
# Redis (optional)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379/0"
# REDIS_HOST="localhost"
# REDIS_PORT="6379"
# REDIS_PASSWORD=""
# REDIS_DB="0"

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# CORS_ORIGINS is primary; ALLOWED_ORIGINS is an alias (e.g. Docker samples)
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
# ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8080"
CORS_ALLOW_CREDENTIALS="true"
CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS,PATCH"
CORS_ALLOW_HEADERS="*"

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE="60"
RATE_LIMIT_REQUESTS_PER_HOUR="1000"
RATE_LIMIT_WINDOW_SECONDS="60"
RATE_LIMIT_BURST_LIMIT="10"

# -----------------------------------------------------------------------------
# API documentation (HTTP Basic for /docs, /redoc, OpenAPI)
# -----------------------------------------------------------------------------
# When BOTH are set, UIs require Basic auth. Leave unset for open local dev.
# DOCS_USERNAME="dev"
# DOCS_PASSWORD="change-me"
# OPENAPI_URL="/openapi.json"
# DOCS_EXTRA_PROTECTED_PATHS=""

# -----------------------------------------------------------------------------
# Postman export (see README — `postman/` output)
# -----------------------------------------------------------------------------
# POSTMAN_OUTPUT_DIR="postman"
# POSTMAN_COLLECTION_FILE="postman/postman_collection.json"
# POSTMAN_EXPORT_ENVIRONMENT="0"
# POSTMAN_ENV_FILE="postman_environment.json"
# POSTMAN_COLLECTION_NAME=""
# POSTMAN_BASE_URL=""
# POSTMAN_NEGATIVE_TESTS="true"

# -----------------------------------------------------------------------------
# Telemetry (optional)
# -----------------------------------------------------------------------------
# TELEMETRY_ENABLED="false"
# DATADOG_ENABLED="false"

# -----------------------------------------------------------------------------
# Docker Compose — infrastructure only (ports, DB container, GUIs, nginx)
# Used by docker-compose.yml; not all are read by the Python app directly.
# -----------------------------------------------------------------------------
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me-in-production"
POSTGRES_DB="fastmvc"
POSTGRES_PORT="5432"

REDIS_PORT="6379"

PGADMIN_EMAIL="admin@example.com"
PGADMIN_PASSWORD="admin"
PGADMIN_PORT="5050"

REDIS_INSIGHT_PORT="5540"

NGINX_HTTP_PORT="80"
NGINX_HTTPS_PORT="443"

# -----------------------------------------------------------------------------
# Optional: LLM providers (keys only in env — never commit real secrets)
# -----------------------------------------------------------------------------
OPENAI_ENABLED="false"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-4.1-mini"

ANTHROPIC_ENABLED="false"
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL=""
ANTHROPIC_MODEL="claude-3-5-sonnet-20240620"

OLLAMA_ENABLED="false"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

GEMINI_ENABLED="false"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# -----------------------------------------------------------------------------
# Optional: push notifications (APNS / FCM)
# -----------------------------------------------------------------------------
APNS_ENABLED="false"
APNS_KEY_ID=""
APNS_TEAM_ID=""
APNS_BUNDLE_ID=""
APNS_PRIVATE_KEY_PATH=""
APNS_USE_SANDBOX="true"

FCM_ENABLED="false"
FCM_SERVER_KEY=""
FCM_PROJECT_ID=""

# -----------------------------------------------------------------------------
# Development (uvicorn)
# -----------------------------------------------------------------------------
RELOAD="true"
# WORKERS="4"
